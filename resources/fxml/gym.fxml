<VBox alignment="TOP_CENTER" minHeight="800.0" minWidth="1000.0" prefHeight="800.0" prefWidth="1000.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Gym.Gym"> <!-- controller! refers to package-path.ControllerClassName that has the logic for any actions here! -->
  <children>
    <AnchorPane maxHeight="-1.0" maxWidth="-1.0" prefHeight="-1.0" prefWidth="-1.0" VBox.vgrow="ALWAYS">
      <children>
            <StackPane fx:id="mainStage" prefHeight="600.0" prefWidth="800.0" AnchorPane.leftAnchor="5.0" AnchorPane.topAnchor="20.0">
               <children>
                  <Rectangle arcHeight="5.0" arcWidth="5.0" fill="#ffe88a7c" height="600.0" stroke="BLACK" strokeType="INSIDE" width="800.0" />
                  <AnchorPane prefHeight="200.0" prefWidth="200.0">
                     <children>
                        <Rectangle arcHeight="5.0" arcWidth="5.0" fill="#ff90213c" height="300.0" stroke="BLACK" strokeType="INSIDE" width="400.0" />
                        <Rectangle arcHeight="5.0" arcWidth="5.0" fill="#ff901f" height="300.0" layoutX="400.0" stroke="BLACK" strokeType="INSIDE" width="400.0" />
                        <AnchorPane fx:id="targetMember" layoutX="14.0" layoutY="419.0" prefHeight="60.0" prefWidth="60.0">
                           <children>
                              <Circle fill="#22ff1f" layoutX="30.0" layoutY="30.0" radius="30.0" stroke="BLACK" strokeType="INSIDE" />
                              <Circle fill="#21fbff00" layoutX="30.0" layoutY="30.0" radius="20.0" stroke="BLACK" strokeType="INSIDE" strokeWidth="3.0" />
                           </children>
                        </AnchorPane>
                        <HBox fx:id="otherMembers" layoutX="420.0" layoutY="150.0" prefHeight="100.0" prefWidth="200.0">
                           <children>
                              <Circle fill="#22ff1f" radius="30.0" stroke="BLACK" strokeType="INSIDE" />
                              <Circle fill="#22ff1f" radius="30.0" stroke="BLACK" strokeType="INSIDE" />
                              <Circle fill="#22ff1f" radius="30.0" stroke="BLACK" strokeType="INSIDE" />
                              <Circle fill="#22ff1f" radius="30.0" stroke="BLACK" strokeType="INSIDE" />
                              <Circle fill="#22ff1f" radius="30.0" stroke="BLACK" strokeType="INSIDE" />
                           </children>
                        </HBox>
                        <Circle fx:id="targetInstructor" fill="#d476ff" layoutX="600.0" layoutY="50.0" radius="30.0" stroke="BLACK" strokeType="INSIDE" />
                     </children>
                  </AnchorPane>
               </children>
            </StackPane>
            <VBox layoutX="14.0" layoutY="611.0" prefHeight="70.0" prefWidth="514.0" style="-fx-background-color: lightgrey;" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="5.0">
               <children>
                  <Label alignment="TOP_CENTER" prefHeight="26.0" prefWidth="518.0" text="Scenario Control Panel">
                     <font>
                        <Font size="16.0" />
                     </font>
                  </Label>
                  <GridPane alignment="TOP_CENTER" nodeOrientation="RIGHT_TO_LEFT">
                     <columnConstraints>
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                     </columnConstraints>
                     <rowConstraints>
                        <RowConstraints maxHeight="20.8" minHeight="0.0" prefHeight="0.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                     </rowConstraints>
                     <children>
                        <Button fx:id="startButton" alignment="TOP_CENTER" minWidth="100.0" mnemonicParsing="false" onMouseClicked="#start" text="Start" GridPane.columnIndex="2" GridPane.halignment="CENTER" GridPane.rowIndex="1" GridPane.valignment="BASELINE" />
                        <Button fx:id="nextButton" alignment="TOP_CENTER" disable="true" minWidth="100.0" mnemonicParsing="false" onMouseClicked="#next" text="Next" GridPane.columnIndex="1" GridPane.halignment="CENTER" GridPane.rowIndex="1" GridPane.valignment="BASELINE" />
