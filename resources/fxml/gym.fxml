                     </children>
                  </GridPane>
               </children>
            </VBox>
            <VBox layoutX="647.0" layoutY="646.0" prefHeight="70.0" prefWidth="338.0" style="-fx-background-color: lavender;" AnchorPane.bottomAnchor="20.0" AnchorPane.rightAnchor="5.0">
               <children>
                  <Label alignment="TOP_CENTER" prefHeight="26.0" prefWidth="473.0" text="Application Simluator">
                     <font>
                        <Font size="16.0" />
                     </font>
                  </Label>
                  <GridPane alignment="TOP_CENTER" nodeOrientation="RIGHT_TO_LEFT">
                    <columnConstraints>
                      <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                      <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                    </columnConstraints>
                    <rowConstraints>
                      <RowConstraints maxHeight="20.8" minHeight="0.0" prefHeight="0.0" vgrow="SOMETIMES" />
                      <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                    </rowConstraints>
                     <children>
                        <Button alignment="TOP_CENTER" mnemonicParsing="false" nodeOrientation="RIGHT_TO_LEFT" onMouseClicked="#startMemberApp" text="Member Application" GridPane.halignment="CENTER" GridPane.valignment="BASELINE" />
                        <Button alignment="TOP_CENTER" mnemonicParsing="false" onMouseClicked="#startInstructorApp" text="Instructor Application" GridPane.columnIndex="1" GridPane.halignment="CENTER" GridPane.valignment="BASELINE" />
                     </children>
                  </GridPane>
               </children>
            </VBox>
            <VBox layoutX="830.0" layoutY="20.0" prefHeight="252.0" prefWidth="169.0" style="-fx-background-color: #fca7cd;" AnchorPane.rightAnchor="5.0" AnchorPane.topAnchor="20.0">
               <children>
                  <Label alignment="TOP_CENTER" prefHeight="0.0" prefWidth="514.0" text="TESTING SIGNALS">
                     <font>
                        <Font size="16.0" />
                     </font>
                  </Label>
                  <GridPane alignment="TOP_CENTER" nodeOrientation="RIGHT_TO_LEFT" prefHeight="316.0" prefWidth="514.0">
                     <columnConstraints>
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                     </columnConstraints>
                     <rowConstraints>
                        <RowConstraints vgrow="SOMETIMES" />
                        <RowConstraints vgrow="SOMETIMES" />
                        <RowConstraints vgrow="SOMETIMES" />
                        <RowConstraints vgrow="SOMETIMES" />
                        <RowConstraints vgrow="SOMETIMES" />
                     </rowConstraints>
                     <children>
                        <Button alignment="TOP_CENTER" mnemonicParsing="false" onMouseClicked="#testCameraFeed" text="Camera Feed" GridPane.halignment="CENTER" GridPane.valignment="BASELINE" />
                        <Button alignment="TOP_CENTER" mnemonicParsing="false" onMouseClicked="#testWearableSignal" text="Wearable" GridPane.halignment="CENTER" GridPane.rowIndex="1" GridPane.valignment="BASELINE" />
                        <Button alignment="TOP_CENTER" mnemonicParsing="false" onMouseClicked="#testAudioSensor" text="Audio" GridPane.halignment="CENTER" GridPane.rowIndex="2" GridPane.valignment="BASELINE" />
                        <Button alignment="TOP_CENTER" mnemonicParsing="false" onMouseClicked="#testDoorwaySensor" text="Doorway" GridPane.halignment="CENTER" GridPane.rowIndex="3" GridPane.valignment="BASELINE" />
                        <Button alignment="TOP_CENTER" mnemonicParsing="false" onMouseClicked="#sendAll3Signals" text="Camera, Wearable, &amp; Audio" GridPane.halignment="CENTER" GridPane.rowIndex="4" GridPane.valignment="BASELINE" />
                     </children>
                  </GridPane>
               </children>
            </VBox>
            <VBox layoutX="825.0" layoutY="286.0" prefHeight="377.0" prefWidth="170.0" style="-fx-background-color: #fcd2e5;" AnchorPane.rightAnchor="5.0">
               <children>
                  <Label alignment="TOP_CENTER" prefHeight="0.0" prefWidth="514.0" text="Logging (?)">
                     <font>
                        <Font size="16.0" />
                     </font>
                  </Label>
                  <TextArea id="frontendLogger" fx:id="frontendLogger" editable="false" prefHeight="356.0" prefWidth="170.0" text="GSMS Initialized." wrapText="true" />
               </children>
            </VBox>
      </children>
    </AnchorPane>
  </children>
</VBox>
